---
interface Props {
  lang: 'pl' | 'en';
}

const { lang } = Astro.props;
const isPl = lang === 'pl';

interface Poster {
  year: number;
  src: string;
}

const posters: Poster[] = [
  { year: 2025, src: "../assets/img/plakaty/2023.webp" }, // Placeholder for current
  { year: 2024, src: "../assets/img/plakaty/2023.webp" }, // Placeholder
  { year: 2023, src: "../assets/img/plakaty/2023.webp" },
  { year: 2022, src: "../assets/img/plakaty/2022.webp" },
  { year: 2021, src: "../assets/img/plakaty/2021.webp" },
  { year: 2020, src: "../assets/img/plakaty/2020.webp" },
  { year: 2019, src: "../assets/img/plakaty/2019.webp" },
  { year: 2018, src: "../assets/img/plakaty/2018.webp" },
  { year: 2017, src: "../assets/img/plakaty/2017.webp" },
  { year: 2016, src: "../assets/img/plakaty/2016.webp" },
  { year: 2015, src: "../assets/img/plakaty/2015.webp" },
  { year: 2014, src: "../assets/img/plakaty/2014.webp" },
  { year: 2013, src: "../assets/img/plakaty/2013.webp" }
];
---

<section class="page-section alt" aria-labelledby="posters-gallery-title">
    <div class="section-inner">
        <h2 id="posters-gallery-title" class="section-title">
            {isPl ? "Kronika Festiwalu: Archiwum Plakatów" : "Festival Chronicle: Poster Archive"}
        </h2>
        <div class="poster-grid">
            {posters.map(poster => (
                <figure class="poster-item">
                    <a href={poster.src} class="poster-link">
                        <img src={poster.src} alt={`Plakat edycji MASSKA ${poster.year}`} loading="lazy" decoding="async" />
                        <figcaption class="poster-caption">MASSKA {poster.year}</figcaption>
                    </a>
                </figure>
            ))}
        </div>
    </div>
</section>

<!-- Modern Custom Lightbox Modal -->
<div id="poster-lightbox" class="lightbox-modal" aria-hidden="true" role="dialog">
    <button class="lightbox-close" aria-label={isPl ? "Zamknij podgląd" : "Close preview"}>&times;</button>
    <button class="lightbox-nav lightbox-prev" aria-label={isPl ? "Poprzedni plakat" : "Previous poster"}>&#8249;</button>
    <div class="lightbox-content">
        <img id="lightbox-img" src="" alt="" />
        <div id="lightbox-caption" class="lightbox-caption"></div>
    </div>
    <button class="lightbox-nav lightbox-next" aria-label={isPl ? "Następny plakat" : "Next poster"}>&#8250;</button>
</div>

<script>
    const links = document.querySelectorAll('.poster-link');
    const modal = document.getElementById('poster-lightbox');
    const img = document.getElementById('lightbox-img') as HTMLImageElement;
    const caption = document.getElementById('lightbox-caption');
    const closeBtn = modal?.querySelector('.lightbox-close');
    const prevBtn = modal?.querySelector('.lightbox-prev');
    const nextBtn = modal?.querySelector('.lightbox-next');

    let currentIndex = 0;

    img?.addEventListener('load', () => {
        img.classList.remove('is-switching');
        caption?.classList.remove('is-switching');
    });

    function openLightbox(index: number) {
        if (!modal || !img || !caption) return;
        currentIndex = index;
        const link = links[currentIndex];
        const imageSrc = link.getAttribute('href');
        const captionText = link.querySelector('.poster-caption')?.textContent || '';

        if (imageSrc) {
            img.classList.remove('is-switching');
            caption.classList.remove('is-switching');
            img.src = imageSrc;
            caption.textContent = captionText;
            modal.setAttribute('aria-hidden', 'false');
            modal.classList.add('is-active');
            document.body.style.overflow = 'hidden';
        }
    }

    function closeLightbox() {
        if (!modal || !img || !caption) return;
        modal.setAttribute('aria-hidden', 'true');
        modal.classList.remove('is-active');
        document.body.style.overflow = '';
        setTimeout(() => {
            img.src = '';
            caption.textContent = '';
        }, 300);
    }

    function navigate(direction: number) {
        if (!img || !caption) return;
        let newIndex = currentIndex + direction;
        if (newIndex < 0) {
            newIndex = links.length - 1;
        } else if (newIndex >= links.length) {
            newIndex = 0;
        }

        const link = links[newIndex];
        const imageSrc = link.getAttribute('href');
        const captionText = link.querySelector('.poster-caption')?.textContent || '';

        if (imageSrc) {
            img.classList.add('is-switching');
            caption.classList.add('is-switching');
            setTimeout(() => {
                currentIndex = newIndex;
                img.src = imageSrc;
                caption.textContent = captionText;
            }, 150); // wait for fade out
        }
    }

    links.forEach((link, index) => {
        link.addEventListener('click', (e) => {
            e.preventDefault();
            openLightbox(index);
        });
    });

    closeBtn?.addEventListener('click', closeLightbox);

    modal?.addEventListener('click', (e) => {
        if (e.target === modal || e.target === modal.querySelector('.lightbox-content')) {
            closeLightbox();
        }
    });

    prevBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        navigate(-1);
    });

    nextBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        navigate(1);
    });

    document.addEventListener('keydown', (e) => {
        if (!modal || !modal.classList.contains('is-active')) return;
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') navigate(-1);
        if (e.key === 'ArrowRight') navigate(1);
    });

    // Touch Swipe Navigation for Mobile
    let touchStartX = 0;
    let touchEndX = 0;
    const swipeThreshold = 50; // minimum X diff to trigger swipe

    modal?.addEventListener('touchstart', (e: any) => {
        if (e.touches && e.touches.length > 0) {
            touchStartX = e.touches[0].clientX;
        }
    }, { passive: true });

    modal?.addEventListener('touchend', (e: any) => {
        if (e.changedTouches && e.changedTouches.length > 0) {
            touchEndX = e.changedTouches[0].clientX;
            const diff = touchEndX - touchStartX;
            if (Math.abs(diff) > swipeThreshold) {
                if (diff > 0) {
                    navigate(-1); // Swipe right -> previous
                } else {
                    navigate(1);  // Swipe left -> next
                }
            }
        }
    }, { passive: true });
</script>

<style>
    .poster-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 2.5rem;
        margin-top: 3rem;
    }

    .poster-item {
        margin: 0;
        overflow: hidden;
        border-radius: 12px;
        background: var(--color-bg-card, #222);
        border: 1px solid var(--color-border, #333);
        transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.3s ease, border-color 0.3s ease;
    }

    .poster-item a {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .poster-item:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
        border-color: var(--color-accent, #ff6b6b);
    }

    .poster-item img {
        width: 100%;
        height: auto;
        aspect-ratio: 1 / 1.4;
        object-fit: cover;
        display: block;
        transition: filter 0.3s ease;
    }

    .poster-item:hover img {
        filter: brightness(1.05);
    }

    .poster-caption {
        padding: 1rem;
        text-align: center;
        font-weight: 500;
        font-size: 1.1rem;
        letter-spacing: 0.5px;
        background: var(--color-bg-caption, #1b1b1b);
        border-top: 1px solid var(--color-border, #333);
    }

    /* Lightbox Modal Styles */
    .lightbox-modal {
        position: fixed;
        inset: 0;
        background: rgba(10, 11, 15, 0.9);
        backdrop-filter: blur(15px);
        z-index: 10000;
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
        touch-action: none; /* Disable default browser scrolling/zooming on the modal to allow swipe */
    }

    .lightbox-modal.is-active {
        opacity: 1;
        pointer-events: auto;
    }

    .lightbox-content {
        position: relative;
        max-width: 85%;
        max-height: 85vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        transform: scale(0.9);
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .lightbox-modal.is-active .lightbox-content {
        transform: scale(1);
    }

    .lightbox-content img {
        max-width: 100%;
        max-height: 70vh;
        object-fit: contain;
        border-radius: 8px;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
        transition: opacity 0.2s ease, transform 0.2s ease;
        opacity: 1;
        transform: scale(1);
    }

    .lightbox-content img.is-switching {
        opacity: 0;
        transform: scale(0.97);
    }

    .lightbox-caption {
        color: #fff;
        margin-top: 1.5rem;
        font-size: 1.25rem;
        font-weight: 500;
        letter-spacing: 0.5px;
        text-align: center;
        transition: opacity 0.2s ease;
        opacity: 1;
    }

    .lightbox-caption.is-switching {
        opacity: 0;
    }

    .lightbox-close {
        position: absolute;
        top: 2rem;
        right: 2rem;
        background: none;
        border: none;
        color: rgba(255, 255, 255, 0.7);
        font-size: 3rem;
        cursor: pointer;
        transition: color 0.2s, transform 0.2s, background 0.2s;
        z-index: 10100;
        width: 50px;
        height: 50px;
        display: flex;
        justify-content: center;
        align-items: center;
        border-radius: 50%;
    }

    .lightbox-close:hover {
        color: #fff;
        transform: rotate(90deg);
        background: rgba(255, 255, 255, 0.1);
    }

    .lightbox-nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #fff;
        font-size: 2.5rem;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        justify-content: center;
        align-items: center;
        transition: background 0.2s, transform 0.2s;
        z-index: 10100;
    }

    .lightbox-nav:hover {
        background: rgba(255, 255, 255, 0.15);
        transform: translateY(-50%) scale(1.05);
    }

    .lightbox-prev {
        left: 2rem;
    }

    .lightbox-next {
        right: 2rem;
    }

    @media (max-width: 768px) {
        .poster-grid {
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 1.5rem;
        }
        
        .poster-caption {
            font-size: 0.95rem;
            padding: 0.75rem;
        }

        .lightbox-nav {
            width: 45px;
            height: 45px;
            font-size: 1.8rem;
        }
        
        .lightbox-prev {
            left: 1rem;
        }
        
        .lightbox-next {
            right: 1rem;
        }
        
        .lightbox-close {
            top: 1rem;
            right: 1rem;
            font-size: 2.2rem;
        }
    }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Static page generated automatically from HTML
---
<BaseLayout
  title="Contact · MASSKA 2025"
  description="Contact the organizers of MASSKA festival. Contact form, email addresses and festival office information."
  lang="en"
  showPartners={true}
  redirectToPreferredLanguage={true}
>
<section class="hero">
            <div class="hero-text">
                <p class="eyebrow">Have questions?</p>
                <h1>Get in touch</h1>
                <p>We're here to answer all your questions about MASSKA 2025 festival. Fill out the form or write
                    directly to our email address.</p>
            </div>
        </section>

        <section class="page-section" aria-labelledby="contact-form">
            <div class="section-inner two-column">
                <div>
                    <h2 id="contact-form">Contact form</h2>
                    <p>Fill out the form below and we'll get back to you as soon as possible. All fields are required.
                    </p>

                    <form action="https://formspree.io/f/xanawjzb" method="POST" class="contact-form">
                        <div class="form-group">
                            <label for="name">Full name <span aria-label="required">*</span></label>
                            <input type="text" id="name" name="name" required aria-required="true">
                        </div>

                        <div class="form-group">
                            <label for="email">Email address <span aria-label="required">*</span></label>
                            <input type="email" id="email" name="_replyto" required aria-required="true">
                        </div>

                        <div class="form-group">
                            <label for="subject">Subject <span aria-label="required">*</span></label>
                            <input type="text" id="subject" name="_subject" required aria-required="true">
                        </div>

                        <div class="form-group">
                            <label for="message">Message <span aria-label="required">*</span></label>
                            <textarea id="message" name="message" rows="6" required aria-required="true"></textarea>
                        </div>

                        <input type="hidden" name="_language" value="en">
                        <input type="text" name="_gotcha" style="display:none">

                        <button type="submit" class="button primary">Send message</button>
                    </form>
                </div>

                <aside class="info-panel" aria-label="Contact information">
                    <h2>Information</h2>

                    <h3>Contact form</h3>
                    <p>
                        Fill out the form and we'll respond to your inquiry as soon as possible.
                    </p>

                    <h3>Festival address</h3>
                    <p>
                        Aleja Franciszka Mamuszki 14<br>
                        81-702 Sopot<br>
                        Poland
                    </p>

                    <h3>Response time</h3>
                    <p>
                        We typically respond within 2-3 business days. During the festival period (November 16–20) there
                        may be slight delays.
                    </p>

                    <div style="margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border);">
                        <p class="muted" style="font-size: 0.9rem;">
                            <strong>Note:</strong><br>
                            Please direct all inquiries exclusively through the contact form.
                        </p>
                    </div>
                </aside>
            </div>
        </section>

        <section class="page-section alt" aria-labelledby="frequently-asked-questions">
            <div class="section-inner">
                <h2 id="frequently-asked-questions">Frequently asked questions</h2>
                <div class="card-grid">
                    <article class="card">
                        <h3>How to register for workshops?</h3>
                        <p>Workshop registration is available through the contact form. Please specify which workshop
                            you're interested in. Places are limited.</p>
                    </article>
                    <article class="card">
                        <h3>Are performances available online?</h3>
                        <p>Yes! Selected performances are available on our <a href="online.html">online platform</a>.</p>
                    </article>
                    <article class="card">
                        <h3>How to get to the venues?</h3>
                        <p>All festival venues are located in Sopot and are easily accessible by public transport.
                            Detailed information available in the <a href="program.html">Program</a> section.</p>
                    </article>
                </div>
            </div>
        </section>
</BaseLayout>

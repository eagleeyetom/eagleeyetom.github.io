                        </a>
                    </figure>
                    <figure role="listitem">
                        <a href="https://bart.sopot.pl/" target="_blank" rel="noopener noreferrer">
                            <img src="../assets/img/bart.webp" alt="Baltic Artistic Agency BART">
                        </a>
                    </figure>
                    <figure role="listitem">
                        <a href="https://www.facebook.com/mamuszki14" target="_blank" rel="noopener noreferrer">
                            <img src="../assets/img/mamuszki-14.webp" alt="Mamuszki 14">
                        </a>
                    </figure>

---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Static page generated automatically from HTML
---
<BaseLayout
  title="Schedule · MASSKA 2025"
  description="Schedule of XXIV MASSKA International Theatre Review 2025. Performances, workshops and events from November 16-20 in Sopot."
  lang="en"
  showPartners={true}
  redirectToPreferredLanguage={true}
>
<section class="hero">
            <div class="hero-text">
                <p class="eyebrow">XXIV International Theatre Review</p>
                <h1>MASSKA 2025 Festival Program</h1>
                <p>Five days of extraordinary performances, workshops and theatrical encounters. From November 16-20,
                    2025 in Sopot
                    — theatre ensembles present their finest works.</p>
                <div class="hero-actions">
                    <a class="button primary" href="online.html">Watch streams</a>
                    <a class="button secondary"
                        href="https://docs.google.com/forms/d/1-cCnZtjLfHMI9uyEodcN6xm2t2ZBQPrVYIwB4eLu0yE/viewform"
                        target="_blank" rel="noopener noreferrer">Theatre submission</a>
                </div>
                <div class="chip-row" role="list">
                    <span class="chip" role="listitem">5 days of events</span>
                    <span class="chip" role="listitem">3 venues</span>
                    <span class="chip" role="listitem">Workshops & performances</span>
                </div>
            </div>
            <figure class="hero-media">
                <img src="../assets/img/head.webp" alt="MASSKA 2025 Festival Program" decoding="async"
                    fetchpriority="high">
            </figure>
        </section>

        <section class="page-section alt" aria-labelledby="venues">
            <div class="section-inner">
                <h2 id="venues">Festival venues</h2>
                <div class="card-grid">
                    <article class="card">
                        <h3>Mamuszki 14</h3>
                        <p>Main festival stage. Aleja Franciszka Mamuszki 14, Sopot — venue for most performances.</p>
                    </article>
                    <article class="card">
                        <h3>Teatr Atelier</h3>
                        <p>Rehearsal and workshop space. Aleja Franciszka Mamuszki 2, Sopot — puppet animation, dance
                            and voice workshops.</p>
                    </article>
                    <article class="card">
                        <h3>Wybrzeże Theatre Chamber Stage</h3>
                        <p>Additional performance space. Aleja Bohaterów Monte Cassino 30, Sopot.</p>
                    </article>
                </div>
            </div>
        </section>

        <section class="page-section" aria-labelledby="detailed-program">
            <div class="section-inner">
                <h2 id="detailed-program">Detailed schedule</h2>

                <div class="timeline">
                    <div class="timeline-item">
                        <h3>Sunday, November 16, 2025</h3>
                        <p><strong>Mamuszki 14</strong></p>
                        <ul>
                            <li><strong>4:00 PM</strong> — Teatr Krzesiwo (Warsaw): <em>Cut Daffodils</em> (40 min)</li>
                            <li><strong>5:30 PM</strong> — Teatr Otczapy (Września): <em>My Two Heads</em> (50 min)
                            </li>
                        </ul>
                    </div>

                    <div class="timeline-item">
                        <h3>Monday, November 17, 2025</h3>
                        <p><strong>Mamuszki 14</strong></p>
                        <ul>
                            <li><strong>10:45 AM</strong> — Teatr Fieter (Ozimek): <em>The Wawel Dragon</em> (30 min)
                            </li>
                            <li><strong>12:15 PM</strong> — Teatr Cienie (Jarosław): <em>Moses</em> (30 min)</li>
                            <li><strong>12:50 PM</strong> — Small Big Band (Łódź): <em>Musical Mosaic</em> (15 min)</li>
                            <li><strong>1:20 PM</strong> — Teatr EF (Bielsko-Biała): <em>ABC</em> (35 min)</li>
                        </ul>

                        <p><strong>Teatr Atelier (rehearsal room)</strong></p>
                        <ul>
                            <li><strong>2:00–4:00 PM</strong> — Puppet animation workshop <br><small>Led by: Natalka
                                    Smyk and Aleksandra Małecka</small></li>
                            <li><strong>2:00–4:00 PM</strong> — Dance workshop <br><small>Led by: Róża Kołoda</small>
                            </li>
                        </ul>

                        <p><strong>Wybrzeże Theatre Chamber Stage</strong></p>
                        <ul>
                            <li><strong>10:00 AM</strong> — Teatr Pogotowie Teatralne (Legnica): <em>A Story That Wanted
                                    to Be Told</em> (40 min)</li>
                            <li><strong>11:15 AM</strong> — Teatr Euforia (Głosków): <em>When I'm Not Here</em> (30 min)
                            </li>
                            <li><strong>5:00 PM</strong> — Teatr Osobliwy (Słupsk): <em>Spun</em> (40 min)</li>
                            <li><strong>6:15 PM</strong> — Poor Theatre of Emotions (Sopot): <em>He and She - A
                                    Fairytale Without a Moral</em> <span class="badge">30 min</span></li>
                            <li><strong>7:20 PM</strong> — Teatr S.A.N. Rafał Paśko (Przemyśl): <em>Yonder</em> (50 min)
                            </li>
                        </ul>

                        <p><strong>Evening</strong></p>
                        <ul>
                            <li><strong>8:00–9:30 PM</strong> — <strong>Dance party</strong> for festival participants
                            </li>
                        </ul>
                    </div>

                    <div class="timeline-item">
                        <h3>Tuesday, November 18, 2025</h3>
                        <p><strong>Mamuszki 14</strong></p>
                        <ul>
                            <li><strong>10:00 AM</strong> — Nemno (Rzeszów): <em>The Take</em> (45 min)<br><small>+
                                    meeting with puppet and theatre creators Nemno (Henryk and Dagmara
                                    Hryniewicki)</small></li>
                            <li><strong>12:00 PM</strong> — Teatr Bis (Gdynia): <em>Beak to Beak, or A Day in the Life
                                    of the Neighbourhood</em> (30 min)</li>
                            <li><strong>12:45 PM</strong> — Teatralna 6 (Rumia): <em>A Bomb Fell in the Basement</em>
                                (20 min)</li>
                            <li><strong>1:25 PM</strong> — Teatr Euforion (Wrocław): <em>Ashen Feast</em> (35 min)</li>
                            <li><strong>6:30 PM</strong> — Teatr Alpaka (Gdańsk): <em>To Shine</em> (90 min + 10 min
                                break)</li>
                        </ul>

                        <p><strong>Teatr Atelier (rehearsal room)</strong></p>
                        <ul>
                            <li><strong>2:00–4:00 PM</strong> — Voice projection workshop <br><small>Led by: Aleksandra
                                    Małecka</small></li>
                        </ul>

                        <p><strong>Wybrzeże Theatre Chamber Stage</strong></p>
                        <ul>
                            <li><strong>10:00 AM</strong> — Teatr Czy TAK, Czy NIE (Toruń): <em>Beauty and the
                                    Beast</em> (20 min)</li>
                            <li><strong>11:00 AM</strong> — Folk Amateur Theatre Studio PAROSTKY (Kyiv)</li>
                            <li><strong>5:00 PM</strong> — Teatr Walny/Łątki (Gdańsk/Supraśl): <em>Macbeth</em> (55 min)
                            </li>
                            <li><strong>7:00 PM</strong> — Adam Kuza / Sara Kozłowska (Łódź): <em>The Chairs</em> (45
                                min)</li>
                        </ul>
                    </div>

                    <div class="timeline-item">
                        <h3>Wednesday, November 19, 2025</h3>
                        <p><strong>Mamuszki 14</strong></p>
                        <ul>
                            <li><strong>10:00 AM</strong> — Teatr Smile (Łódź): <em>Warm and Fluffy</em> (25 min)</li>
                            <li><strong>11:00 AM</strong> — Grupa teatralna AA (Rokocin): <em>Against Adversity</em> (10
                                min)</li>
                            <li><strong>11:45 AM</strong> — Remont Pomp (Gdańsk): <em>Concert</em></li>
                            <li><strong>12:30–2:30 PM</strong> — Music workshop <br><small>Led by: Jarek Marciszewski
                                    and Sebastian Włodarek</small></li>
                            <li><strong>5:00 PM</strong> — Teatr Przebudzeni (Ostróda): <em>Antidote</em> (25 min)</li>
                            <li><strong>6:00 PM</strong> — Teatr Fredreum (Przemyśl): <em>Mr. Ear</em> (40 min)</li>
                        </ul>

                        <p><strong>Teatr Atelier (rehearsal room)</strong></p>
                        <ul>
                            <li><strong>1:00–3:00 PM</strong> — Theatre workshop <br><small>Led by: Jarek
                                    Rebeliński</small></li>
                        </ul>
                    </div>

                    <div class="timeline-item">
                        <h3>Thursday, November 20, 2025</h3>
                        <p><strong>Mamuszki 14 — Side events</strong></p>
                        <ul>
                            <li><strong>10:00 AM–12:00 PM</strong> — Film screening <em>Amateurs</em><br><small>+
                                    meeting with actors from Teatr Biuro Rzeczy Osobistych (Gdynia)</small></li>
                        </ul>
                    </div>
                </div>

                <div class="announcement">
                    <p><strong>Notice:</strong> The organizer reserves the right to make changes to the program for
                        reasons beyond their control.</p>
                </div>
            </div>
        </section>

        <section class="page-section alt" aria-labelledby="practical-info">
            <div class="section-inner two-column">
                <div>
                    <h2 id="practical-info">Practical information</h2>
                    <p>The festival takes place in a hybrid format — performances are available live in Sopot and via
                        online streaming.</p>

                    <h3>Accessibility</h3>
                    <p>All festival venues are accessible for people with disabilities. Live performances offer adapted
                        seating and sign language interpretation upon request.</p>

                    <h3>Workshop registration</h3>
                    <p>Workshops are open to festival participants. Limited capacity — please register in advance.</p>
                </div>
                <aside class="info-panel" aria-label="Key practical information">
                    <h2>Organizational contact</h2>
                    <dl>
                        <div>
                            <dt>Questions and inquiries</dt>
                            <dd><a href="contact.html">Contact form</a></dd>
                        </div>
                        <div>
                            <dt>Main venue</dt>
                            <dd>Aleja Franciszka Mamuszki 14<br>81-702 Sopot</dd>
                        </div>
                    </dl>
                </aside>
            </div>
        </section>

